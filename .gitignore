# Python
# __pycache__ directories are generated by Python when it compiles source files (.py) into bytecode (.pyc)
# for performance optimization during runtime
**/__pycache__/**

# Environment
.venv
.env
.venv/*
venv/
venv/*

# Testing
.pytest_cache
tests/.pytest_cache
tests/.pytest_cache/*
tests/unit-tests/.pytest_cache
tests/unit-tests/.pytest_cache/*

# Coverage reports
.coverage
.coverage.*
htmlcov/
*.cover
.pytest_cache/
