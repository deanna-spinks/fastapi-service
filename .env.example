# ===============================
# APPLICATION SETTINGS
# ===============================
APP_NAME="FastAPI Patient Management Service"
APP_VERSION=1.0.0
ENVIRONMENT=DEVELOPMENT  # DEVELOPMENT, STAGING, PRODUCTION
DEBUG=True
LOG_LEVEL=INFO
APP_LOG_LEVEL=${LOG_LEVEL}

# ===============================
# SERVER SETTINGS
# ===============================
HOST=localhost
PORT=8000
RELOAD=True  # Auto-reload on code changes (development only)

# ===============================
# UVICORN SETTINGS
# ===============================
UVICORN_WORKERS=1  # Number of worker processes (increase for production)
UVICORN_LOG_LEVEL=${LOG_LEVEL}  # DEBUG, INFO, WARNING, ERROR, CRITICAL
UVICORN_ACCESS_LOG=True
